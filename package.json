{
  "name": "payment-processing-system",
  "version": "0.1.0",
  "description": "SoluLab mid-level backend assignment: payment processing system with idempotency, retries, concurrency control, and gateway simulation.",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "test": "tsx --test tests/unit/paymentService.test.ts tests/integration/paymentsApi.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "payments",
    "nodejs",
    "typescript",
    "fintech"
  ],
  "author": "Rudra",
  "license": "MIT",
